{
  "manifest_version": 3,
  "name": "KoalaFlyff",
  "version": "1.7",
  "description": "Cross-tab key mapper and multi-boxing utility for WebGL games.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.flyff.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.flyff.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
